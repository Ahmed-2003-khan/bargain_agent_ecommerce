# Primary LLM (GPT-4o) — used by NLU service and LLM Phraser
OPENAI_API_KEY="Your_OPENAI_API_KEY_here"

# Fallback LLM (Groq) — used when OpenAI is unavailable
GROQ_API_KEY="Your_GROQ_API_KEY_here"

# CORS: Comma-separated list of allowed origins, or "*" for all (dev only)
# Example: ALLOWED_ORIGINS=https://tenant1.com,https://tenant2.com
ALLOWED_ORIGINS="*"

# Shared secret for inter-service authentication.
# All microservices verify this key on incoming requests.
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_KEY="my-super-secret-key-123"

# URL of the monolith backend endpoint that receives negotiation outcomes.
# Example: https://your-backend.onrender.com/api/negotiations/
DB_SYNC_URL="https://your-backend-url.com/api/negotiations/"
